{
  "name": "cursor-template-www",
  "version": "1.0.0",
  "description": "Template for web-based projects with optimized workflow",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "rm -rf node_modules/.vite && vite",
    "dev:ssl": "vite",
    "dev:watch": "nodemon --watch src --ext ts,tsx,js,jsx,css --exec 'npm run dev'",
    "dev:persistent": "concurrently \"npm run dev:watch\" \"npm run health-check\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:ssl": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:json": "vitest run --reporter=json",
    "test:rufus": "vitest run --reporter=json | node scripts/format-test-output.js",
    "test:watch": "nodemon --watch src --ext ts,tsx,js,jsx,css --exec 'npm run test'",
    "type-check": "node scripts/type-check.js",
    "dev:restart": "node scripts/dev-restart.js",
    "health-check": "node scripts/health-check.js http://localhost:5173 1000",
    "health-check:ssl": "node scripts/health-check.js https://localhost:5173 1000",
    "health-check:ssl-auto": "node scripts/health-check-ssl-auto.js 1000"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "jsdom": "^26.1.0",
    "nodemon": "^3.1.9",
    "typescript": "^5.6.3",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "template",
    "web",
    "react",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "MIT"
}
